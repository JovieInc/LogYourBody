# Jovie is the shared first-party identity authority. Both web and iOS use PKCE.
JOVIE_AUTH_ISSUER=https://jov.ie/api/auth
JOVIE_AUTH_CLIENT_ID=logyourbody-web
JOVIE_AUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Server-only pooled connection for the LYB Neon project.
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
# Dedicated waitlist Neon connection. Keep this separate from product data when configured.
WAITLIST_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Supabase (publishable anon key). Used by the dashboard, photo utils, and data export.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Version (auto-populated in CI)
NEXT_PUBLIC_VERSION=local-dev

# Optional: analytics/telemetry providers. Leave blank to disable.
NEXT_PUBLIC_STATSIG_CLIENT_KEY=
NEXT_PUBLIC_STATSIG_ENV_TIER=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_APP_VERSION=

# Landing page mode. Unset/false = minimal 100vh waitlist hero (production default).
# Set to 1 locally or in preview to render the full System B marketing landing.
NEXT_PUBLIC_LYB_FULL_LANDING=

# Rollback gate for the art-directed minimal waitlist landing. Defaults off.
NEXT_PUBLIC_LYB_LANDING_ART_DIRECTION_V2=

# Pre-launch editorial waitlist v2. Defaults off; enable for preview/internal cohorts.
NEXT_PUBLIC_LYB_WAITLIST_V2=

# OpenAI API Configuration (for avatar generation)
# NEVER commit your actual API key to version control
OPENAI_API_KEY=your-openai-api-key-here
