# Supabase product session and data plane. Configure custom OIDC provider
# `custom:jovie` in the Supabase dashboard; its client secret stays there.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Database
POSTGRES_DATABASE=postgres

# Optional: RevenueCat (for subscriptions)
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY=your-revenuecat-key

# Optional: Version (auto-populated in CI)
NEXT_PUBLIC_VERSION=local-dev

# Landing page mode. Unset/false = minimal 100vh waitlist hero (production default).
# Set to 1 locally or in preview to render the full System B marketing landing.
NEXT_PUBLIC_LYB_FULL_LANDING=

# Pre-launch editorial waitlist v2. Defaults off; enable for preview/internal cohorts.
NEXT_PUBLIC_LYB_WAITLIST_V2=

# OpenAI API Configuration (for avatar generation)
# NEVER commit your actual API key to version control
OPENAI_API_KEY=your-openai-api-key-here
