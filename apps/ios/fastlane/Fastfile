  desc "Upload dSYMs to Sentry using sentry-cli"
  lane :sentry_upload_symbols do |options|
    auth_token = ENV["SENTRY_AUTH_TOKEN"]
    org = ENV["SENTRY_ORG"] || "jovie"
    project = ENV["SENTRY_PROJECT"] || "log-your-body-ios"

    if auth_token.to_s.empty?
      UI.message("SENTRY_AUTH_TOKEN not set, skipping Sentry dSYM upload")
    elsif !system("which sentry-cli > /dev/null 2>&1")
      UI.important("sentry-cli not found in PATH, skipping Sentry dSYM upload")
    else
      dsym_dir = options[:dsym_dir] || "./build"

      UI.message("Uploading dSYMs from #{dsym_dir} to Sentry project #{org}/#{project}")
      sh("SENTRY_AUTH_TOKEN=#{auth_token} SENTRY_ORG=#{org} SENTRY_PROJECT=#{project} sentry-cli upload-dif \"#{dsym_dir}\"")
    end
  end

eval(
  File.read(File.expand_path("Fastfile.release", __dir__)),
  binding,
  File.expand_path("Fastfile.release", __dir__)
)

  error do |lane, exception|
    # Handle errors
    UI.error("🔥 Lane #{lane} failed with error: #{exception.message}")
    UI.error("🔍 Backtrace:\n#{exception.backtrace.join("\n")}")
  end

  desc "Post-build success actions"
  lane :notify_success do |options|
    UI.success("🎉 Build succeeded for #{options[:context] || 'unknown context'}")
    # Add Slack or Discord integration here if desired
  end

  desc "Debug environment variables"
  lane :debug_env do
    UI.header("Environment Variables")
    UI.message("APP_STORE_CONNECT_API_KEY_ID: #{ENV['APP_STORE_CONNECT_API_KEY_ID']}")
    UI.message("APP_STORE_CONNECT_API_ISSUER_ID: #{ENV['APP_STORE_CONNECT_API_ISSUER_ID']}")
    UI.message("APP_STORE_CONNECT_API_KEY_PATH: #{ENV['APP_STORE_CONNECT_API_KEY_PATH']}")
    UI.message("APPLE_TEAM_ID: #{ENV['APPLE_TEAM_ID']}")
    UI.message("MATCH_GIT_URL: #{ENV['MATCH_GIT_URL']}")

    if File.exist?(ENV['APP_STORE_CONNECT_API_KEY_PATH'] || "")
      UI.success("✅ API Key file exists at: #{ENV['APP_STORE_CONNECT_API_KEY_PATH']}")
    else
      UI.error("❌ API Key file not found")
    end
  end

end
