// Configuration settings file format documentation can be found at:
// https://help.apple.com/xcode/#/dev745c5c974
// 
// This is the safe base configuration. A local, ignored Config.xcconfig is
// optionally included below and overrides these values when present.

// API and authentication configuration
API_BASE_URL = https:/$()/www.logyourbody.com
CLERK_PUBLISHABLE_KEY =
CLERK_FRONTEND_API = https:/$()/clerk.logyourbody.com

// Supabase configuration
SUPABASE_URL =
SUPABASE_ANON_KEY =

// RevenueCat
REVENUE_CAT_API_KEY =

// Statsig analytics
STATSIG_CLIENT_SDK_KEY =
STATSIG_ENVIRONMENT_TIER = development

// Sentry error reporting
SENTRY_DSN =
SENTRY_ENVIRONMENT = development
SENTRY_TRACES_SAMPLE_RATE = 0

// BodySpec integration (optional)
BODYSPEC_CLIENT_ID =
BODYSPEC_REDIRECT_URI = logyourbody:/$()/bodyspec-callback

// Local secrets and environment-specific values belong in this ignored file.
#include? "Config.xcconfig"
