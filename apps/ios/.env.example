# Fastlane Match Configuration
# Copy this to .env and fill in your values

# App Store Connect API Key
APP_STORE_CONNECT_API_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_API_ISSUER_ID=YOUR_ISSUER_ID
APP_STORE_CONNECT_API_KEY_PATH=./fastlane/api_key.json

# Match Configuration
MATCH_GIT_URL=https://github.com/YOUR_ORG/certificates.git
MATCH_GIT_BRANCH=main
MATCH_PASSWORD=YOUR_MATCH_PASSWORD
MATCH_TYPE=development
MATCH_APP_IDENTIFIER=com.logyourbody.app
MATCH_GIT_BASIC_AUTHORIZATION=YOUR_BASIC_AUTH_HEADER


# Apple Developer Account
APPLE_TEAM_ID=YOUR_TEAM_ID
APP_STORE_APP_ID=6755209876

# Optional: Keychain Configuration (for CI/CD)
# MATCH_KEYCHAIN_NAME=login.keychain
# MATCH_KEYCHAIN_PASSWORD=YOUR_KEYCHAIN_PASSWORD
